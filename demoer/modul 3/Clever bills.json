        "jsCode": "const text = $json[\"text\"]; // replace with your actual field name\n\nconst totalElRegning = text.match(/Total\\s+(\\d{1,3}(?:\\.\\d{3})*,\\d{2})(?!\\s*inkl)/);\nconst totalAfgift = text.match(/Total\\s+(-\\d{1,3}(?:\\.\\d{3})*,\\d{2})/);\nconst totalPris = text.match(/Total inkl\\. moms Kr\\.?\\s+(\\d{1,3}(?:\\.\\d{3})*,\\d{2})/);\nconst dateRange = text.match(/(\\d{2}\\.\\d{2}\\.\\d{2})\\s+til\\s+(\\d{2}\\.\\d{2}\\.\\d{2})/);\n\nreturn [\n  {\n    json: {\n      totalElRegning: totalElRegning ? totalElRegning[1] : null,\n      totalAfgift: totalAfgift ? totalAfgift[1] : null,\n      totalPris: totalPris ? totalPris[1] : null,\n      startDate: dateRange ? dateRange[1] : null,\n      endDate: dateRange ? dateRange[2] : null\n    }\n  }\n];\n"

    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of items) {\n    if (!item.binary) {\n        continue;\n    }\n\n    for (const key in item.binary) {\n        const binaryData = item.binary[key];\n\n        const isPdf = (\n            binaryData.mimeType === 'application/pdf' ||\n            binaryData.fileName?.toLowerCase().endsWith('.pdf')\n        );\n\n        if (isPdf) {\n            results.push({\n                json: item.json,\n                binary: {\n                    attachment: binaryData\n                }\n            });\n        }\n    }\n}\n\nreturn results;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1008,
        352
      ],
      "id": "52b32bba-1c06-4e0e-80ba-625b71dfd3e7",
      "name": "Retrieve PDF attachment"
    },
    {
      "parameters": {
        "jsCode": "const text = $json[\"text\"]; // Replace with your actual field name\n\nconst extractNumber = (match) => {\n  if (!match) return null;\n  return parseFloat(match.replace(/\\./g, \"\").replace(\",\", \".\"));\n};\n\nconst totalElRegningMatch = text.match(/Total\\s+(\\d{1,3}(?:\\.\\d{3})*,\\d{2})(?!\\s*inkl)/);\nconst totalPrisMatch = text.match(/Total inkl\\. moms Kr\\.?\\s+(\\d{1,3}(?:\\.\\d{3})*,\\d{2})/);\nconst dateRange = text.match(/(\\d{2}\\.\\d{2}\\.\\d{2})\\s+til\\s+(\\d{2}\\.\\d{2}\\.\\d{2})/);\n\n// Find refund or second Total\nconst refundMatch = text.match(/Tilbagebetaling i alt\\s+(-?\\d{1,3}(?:\\.\\d{3})*,\\d{2})/);\nconst totalMatches = [...text.matchAll(/Total\\s+(-?\\d{1,3}(?:\\.\\d{3})*,\\d{2})(?!\\s*inkl)/g)];\nconst secondTotal = totalMatches.length >= 2 ? totalMatches[1][1] : null;\n\n// Pick refund or second total, and make it positive number\nlet totalAfgiftRaw = refundMatch ? refundMatch[1] : secondTotal || null;\nlet totalAfgift = totalAfgiftRaw\n  ? Math.abs(extractNumber(totalAfgiftRaw))\n  : null;\n\nreturn [\n  {\n    json: {\n      totalElRegning: totalElRegningMatch ? extractNumber(totalElRegningMatch[1]) : null,\n      totalAfgift: totalAfgift,\n      totalPris: totalPrisMatch ? extractNumber(totalPrisMatch[1]) : null,\n      startDate: dateRange ? dateRange[1] : null,\n      endDate: dateRange ? dateRange[2] : null\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        352
      ],
      "id": "8d1f39cc-d949-4254-906b-fce4bc95a626",
      "name": "Get Fields"
    }
